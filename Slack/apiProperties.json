{
    "properties": {
        "connectionParameters": {
            "token": {
                "type": "oauthSetting",
                "oAuthSettings": {
                    "identityProvider": "oauth2generic",
                    "clientId": "[CLIENT_ID]",
                    "scopes": "channels:read channels:history channels:write chat:write users:read users:read.email users.profile:read files:read files:write reactions:read reactions:write pins:read pins:write search:read groups:read groups:history im:read im:history mpim:read mpim:history reminders:read reminders:write bookmarks:read bookmarks:write usergroups:read usergroups:write emoji:read dnd:read dnd:write team:read",
                    "redirectMode": "Global",
                    "redirectUrl": "https://global.consent.azure-apim.net/redirect",
                    "properties": {
                        "IsFirstParty": "False",
                        "IsOnbehalfofLoginSupported": false
                    },
                    "customParameters": {
                        "authorizationUrlTemplate": {
                            "value": "https://slack.com/oauth/v2/authorize"
                        },
                        "authorizationUrlQueryStringTemplate": {
                            "value": "client_id={ClientId}&redirect_uri={RedirectUrl}&response_type=code&scope={Scopes}&state={State}&user_scope={Scopes}"
                        },
                        "tokenUrlTemplate": {
                            "value": "https://slack.com/api/oauth.v2.access"
                        },
                        "tokenBodyTemplate": {
                            "value": "code={Code}&grant_type=authorization_code&redirect_uri={RedirectUrl}&client_id={ClientId}&client_secret={ClientSecret}"
                        },
                        "refreshUrlTemplate": {
                            "value": "https://slack.com/api/oauth.v2.access"
                        },
                        "refreshBodyTemplate": {
                            "value": "grant_type=refresh_token&refresh_token={RefreshToken}&client_id={ClientId}&client_secret={ClientSecret}"
                        }
                    }
                }
            }
        },
        "iconBrandColor": "#4A154B",
        "capabilities": [
            "actions"
        ],
        "publisher": "Troy Taylor",
        "scriptOperations": [
            "InvokeMCP",
            "SendMessage",
            "SearchMessages",
            "ListChannels",
            "GetChannelHistory",
            "GetUserInfo",
            "ListUsers",
            "AddReaction",
            "UploadFile"
        ]
    }
}
