{
    "properties": {
        "connectionParameters": {
            "tenantUrl": {
                "type": "string",
                "uiDefinition": {
                    "displayName": "Tenant URL",
                    "description": "The base URL for your UKG Pro WFM tenant (e.g. https://yourtenant.mykronos.com).",
                    "tooltip": "Enter your UKG Pro WFM tenant base URL with no trailing slash",
                    "constraints": {
                        "required": "true"
                    }
                }
            },
            "username": {
                "type": "securestring",
                "uiDefinition": {
                    "displayName": "Username",
                    "description": "The UKG Pro WFM service account username.",
                    "tooltip": "Enter your UKG Pro WFM service account username",
                    "constraints": {
                        "required": "true"
                    }
                }
            },
            "password": {
                "type": "securestring",
                "uiDefinition": {
                    "displayName": "Password",
                    "description": "The UKG Pro WFM service account password.",
                    "tooltip": "Enter your UKG Pro WFM service account password",
                    "constraints": {
                        "required": "true"
                    }
                }
            },
            "appKey": {
                "type": "securestring",
                "uiDefinition": {
                    "displayName": "App Key",
                    "description": "The integration App Key (client_id) issued by UKG Pro WFM.",
                    "tooltip": "Enter the App Key (used as both client_id and the appkey header)",
                    "constraints": {
                        "required": "true"
                    }
                }
            }
        },
        "policyTemplateInstances": [
            {
                "templateId": "setheader",
                "title": "Inject tenantUrl as request header for script",
                "parameters": {
                    "x-ms-apimTemplateParameter.name": "X-Connection-TenantUrl",
                    "x-ms-apimTemplateParameter.value": "@connectionParameters('tenantUrl')",
                    "x-ms-apimTemplateParameter.existsAction": "override",
                    "x-ms-apimTemplate-policySection": "Request"
                }
            },
            {
                "templateId": "setheader",
                "title": "Inject username as request header for script",
                "parameters": {
                    "x-ms-apimTemplateParameter.name": "X-Connection-Username",
                    "x-ms-apimTemplateParameter.value": "@connectionParameters('username')",
                    "x-ms-apimTemplateParameter.existsAction": "override",
                    "x-ms-apimTemplate-policySection": "Request"
                }
            },
            {
                "templateId": "setheader",
                "title": "Inject password as request header for script",
                "parameters": {
                    "x-ms-apimTemplateParameter.name": "X-Connection-Password",
                    "x-ms-apimTemplateParameter.value": "@connectionParameters('password')",
                    "x-ms-apimTemplateParameter.existsAction": "override",
                    "x-ms-apimTemplate-policySection": "Request"
                }
            },
            {
                "templateId": "setheader",
                "title": "Inject appKey as request header for script",
                "parameters": {
                    "x-ms-apimTemplateParameter.name": "X-Connection-AppKey",
                    "x-ms-apimTemplateParameter.value": "@connectionParameters('appKey')",
                    "x-ms-apimTemplateParameter.existsAction": "override",
                    "x-ms-apimTemplate-policySection": "Request"
                }
            }
        ],
