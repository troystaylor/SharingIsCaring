          "description": "Identity value.",
          "x-ms-summary": "Value"
        }
      }
    },
    "TenantInformation": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "x-ms-summary": "Tenant ID" },
        "name": { "type": "string", "x-ms-summary": "Tenant Name" },
        "url": { "type": "string", "x-ms-summary": "Tenant URL" },
        "country": { "type": "string", "x-ms-summary": "Country" },
        "locale": { "type": "string", "x-ms-summary": "Locale" },
