    "Person": {
      "type": "object",
      "properties": {
        "personIdentity": { "$ref": "#/definitions/PersonIdentity" },
        "personNumber": { "type": "string", "x-ms-summary": "Person Number" },
        "firstName": { "type": "string", "x-ms-summary": "First Name" },
        "lastName": { "type": "string", "x-ms-summary": "Last Name" },
        "fullName": { "type": "string", "x-ms-summary": "Full Name" },
        "email": { "type": "string", "x-ms-summary": "Email" },
        "employmentStatus": { "type": "string", "x-ms-summary": "Employment Status" },
