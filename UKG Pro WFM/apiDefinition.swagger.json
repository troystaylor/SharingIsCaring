  "definitions": {
    "PersonIdentity": {
      "type": "object",
      "properties": {
        "qualifier": {
          "type": "string",
          "description": "Identity qualifier (e.g. PersonNumber, PersonId).",
          "x-ms-summary": "Qualifier"
