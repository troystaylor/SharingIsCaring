{
  "name": "salesforce-copilot-connector",
  "version": "1.0.0",
  "description": "Microsoft 365 Copilot connector for Salesforce CRM data",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "auth-setup": "node scripts/sf-auth-setup.js",
    "generate-local-settings": "node scripts/generate-local-settings.js",
    "lint": "eslint src/**/*.ts",
    "deploy": "azd up",
    "deploy:provision": "azd provision",
    "deploy:deploy": "azd deploy"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0",
    "@azure/identity": "^4.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.0",
    "isomorphic-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
