# ── Salesforce OAuth ──
# Get these from your Salesforce Connected App + sf-auth-setup.js
# Use just your instance name (e.g. yourorg) — the full URL is built automatically.
# Full URL also accepted: https://yourorg.my.salesforce.com
SF_INSTANCE_URL=yourorg
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_REFRESH_TOKEN=your_refresh_token
SF_API_VERSION=v66.0

# ── Auth Flow ──
# "refresh_token" (default) — interactive login once, then refresh automatically
# "client_credentials" — server-to-server, no user interaction
SF_AUTH_FLOW=refresh_token

# ── Microsoft Graph Connector ──
CONNECTOR_ID=salesforceconnector
CONNECTOR_NAME=Salesforce
CONNECTOR_DESCRIPTION=Salesforce CRM data for Microsoft 365 Copilot

# ── Microsoft Entra (Azure AD) ──
# Get these from the Entra app registration (scripts/entra-app-setup.ps1)
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_entra_app_client_id
AZURE_CLIENT_SECRET=your_entra_app_client_secret
