{
    "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.28/MicrosoftTeams.schema.json",
    "manifestVersion": "1.28",
    "version": "1.0.0",
    "id": "{{GUID}}",
    "developer": {
        "name": "{{Company Name}}",
        "websiteUrl": "https://{{company}}.com",
        "privacyUrl": "https://{{company}}.com/privacy",
        "termsOfUseUrl": "https://{{company}}.com/terms"
    },
    "name": {
        "short": "{{Service Name}}",
        "full": "{{Service Name}} for Copilot Cowork"
    },
    "description": {
        "short": "{{One-line description of what the plugin does}}",
        "full": "{{Extended description (up to 4000 chars). Explain the business value: what workflows users can delegate, what data sources are connected, and what outcomes to expect.}}"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "accentColor": "#0078D4",
    "agentSkills": [
        { "folder": "./skills/search-and-explore" },
        { "folder": "./skills/create-and-update" },
        { "folder": "./skills/report-and-summarize" },
        { "folder": "./skills/improve-skills" }
    ]
}
