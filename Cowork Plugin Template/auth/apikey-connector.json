{
    "_comment": "API Key — Use for APIs that authenticate with a static API key or bearer token",
    "agentConnectors": [
        {
            "id": "{{service-name}}-api",
            "displayName": "{{Service Name}} API",
            "description": "{{What data and actions this connector provides}}",
            "toolSource": {
                "remoteMcpServer": {
                    "mcpServerUrl": "https://{{your-mcp-endpoint}}/mcp",
                    "authorization": {
                        "type": "ApiKeyPluginVault",
                        "referenceId": "{{service-name}}-apikey"
                    }
                }
            }
        }
    ]
}
