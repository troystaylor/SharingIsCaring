{
    "swagger": "2.0",
    "info": {
        "title": "Copilot Package Management",
        "description": "Manage Microsoft 365 Copilot agents and apps using the Package Management API. List, inspect, block, unblock, update, and reassign ownership of packages in your tenant catalog. Requires a Microsoft Agent 365 license.",
        "version": "1.0.0",
        "contact": {
            "name": "Troy Taylor",
            "email": "troy@troystaylor.com"
        }
    },
    "host": "graph.microsoft.com",
    "basePath": "/",
    "schemes": [
        "https"
    ],
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "paths": {
        "/mcp": {
            "post": {
                "summary": "Invoke Copilot Package Management MCP",
                "description": "Model Context Protocol endpoint for Copilot Studio integration.",
                "operationId": "InvokeMCP",
                "x-ms-agentic-protocol": "mcp-streamable-1.0",
                "responses": {
                    "200": {
                        "description": "MCP response"
                    }
                }
            }
        },
        "/beta/copilot/admin/catalog/packages": {
            "get": {
                "operationId": "ListPackages",
                "summary": "List packages",
                "description": "Retrieve a list of all Copilot agents and apps available in the tenant catalog. Supports filtering by supported host, element type, and last modified date.",
                "x-ms-visibility": "important",
                "parameters": [
                    {
                        "name": "$filter",
                        "in": "query",
                        "type": "string",
                        "required": false,
                        "description": "OData filter expression. Filter by supportedHosts (Copilot, Outlook, Teams, M365), elementTypes (Bots, DeclarativeAgent, CustomEngineAgent), or lastModifiedDateTime.",
                        "x-ms-summary": "Filter"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response containing packages list.",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "value": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/CopilotPackage"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/beta/copilot/admin/catalog/packages/{id}": {
            "get": {
                "operationId": "GetPackageDetails",
                "summary": "Get package details",
                "description": "Retrieve detailed information for a specific agent or app by ID, including element details, categories, and access information.",
                "x-ms-visibility": "important",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "The unique identifier of the package.",
                        "x-ms-summary": "Package ID",
                        "x-ms-url-encoding": "single"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response containing package details.",
                        "schema": {
                            "$ref": "#/definitions/CopilotPackageDetail"
                        }
                    }
                }
            },
            "patch": {
                "operationId": "UpdatePackage",
                "summary": "Update package",
                "description": "Update a package's allowed and acquired users and groups to control availability and deployment.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "The unique identifier of the package.",
                        "x-ms-summary": "Package ID",
                        "x-ms-url-encoding": "single"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "allowedUsersAndGroups": {
                                    "type": "array",
                                    "description": "Users and groups for whom the package is available.",
                                    "x-ms-summary": "Allowed Users and Groups",
                                    "items": {
                                        "$ref": "#/definitions/PackageAccessEntity"
                                    }
                                },
                                "acquireUsersAndGroups": {
                                    "type": "array",
                                    "description": "Users and groups for whom the package is deployed.",
                                    "x-ms-summary": "Acquire Users and Groups",
                                    "items": {
                                        "$ref": "#/definitions/PackageAccessEntity"
                                    }
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Package updated successfully."
                    }
                }
            }
        },
        "/beta/copilot/admin/catalog/packages/{id}/block": {
            "post": {
                "operationId": "BlockPackage",
                "summary": "Block package",
                "description": "Block a Copilot package to prevent its usage across the organization.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "The unique identifier of the package to block.",
                        "x-ms-summary": "Package ID",
                        "x-ms-url-encoding": "single"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Package blocked successfully."
                    }
                }
            }
        },
        "/beta/copilot/admin/catalog/packages/{id}/unblock": {
            "post": {
                "operationId": "UnblockPackage",
                "summary": "Unblock package",
                "description": "Unblock a Copilot package to allow its usage across the organization.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "The unique identifier of the package to unblock.",
                        "x-ms-summary": "Package ID",
                        "x-ms-url-encoding": "single"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Package unblocked successfully."
                    }
                }
            }
        },
        "/beta/copilot/admin/catalog/packages/{id}/reassign": {
            "post": {
                "operationId": "ReassignPackage",
                "summary": "Reassign package",
                "description": "Reassign ownership of a Copilot package to a different user.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "The unique identifier of the package to reassign.",
                        "x-ms-summary": "Package ID",
                        "x-ms-url-encoding": "single"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "required": [
                                "userId"
                            ],
                            "properties": {
                                "userId": {
                                    "type": "string",
                                    "description": "The user ID of the new package owner.",
                                    "x-ms-summary": "New Owner User ID"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Package ownership reassigned successfully."
                    }
                }
            }
        }
    },
    "definitions": {
