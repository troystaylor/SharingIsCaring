                    "x-ms-summary": "Supported Hosts",
                    "items": {
                        "type": "string"
                    }
                },
                "elementTypes": {
                    "type": "array",
                    "description": "Element types in this package (bot, declarativeAgent, etc.).",
                    "x-ms-summary": "Element Types",
                    "items": {
                        "type": "string"
                    }
                },
                "publisher": {
                    "type": "string",
