        "connectionParameters": {
            "token": {
                "type": "oauthSetting",
                "oAuthSettings": {
                    "identityProvider": "aad",
                    "clientId": "[REPLACE_WITH_CLIENT_ID]",
                    "scopes": ["api://[MCP_SERVER_APP_ID]/access_as_user"],
                    "redirectMode": "Global",
                    "redirectUrl": "https://global.consent.azure-apim.net/redirect",
                    "properties": {
