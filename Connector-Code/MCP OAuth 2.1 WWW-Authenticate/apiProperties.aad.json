                            "value": "api://[MCP_SERVER_APP_ID]"
                        },
                        "loginUri": {
                            "value": "https://login.microsoftonline.com"
                        }
                    }
                }
            }
        },
        "capabilities": [
            "actions"
        ],
        "publisher": "Troy Taylor",
        "stackOwner": "YOUR_STACK_OWNER",
