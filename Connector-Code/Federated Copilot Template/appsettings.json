{
  "McpServer": {
    "Name": "example-mcp",
    "Version": "1.0.0",
    "Title": "Example Federated MCP Server",
    "Description": "Template federated Copilot connector — replace with your connector description"
  },
  "Auth": {
    "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
    "ValidAudiences": [
      "{app-registration-client-id}",
      "api://{app-registration-client-id}"
    ],
    "DocumentationUrl": "https://example.com/docs",
    "Scopes": [ "mcp:tools" ]
  },
  "Upstream": {
    "BaseUrl": "https://api.example.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
