{
    "properties": {
        "connectionParameters": {
            "token": {
                "type": "oauthSetting",
                "oAuthSettings": {
                    "identityProvider": "oauth2",
                    "clientId": "[INSERT_YOUR_KENSHO_CLIENT_ID]",
                    "scopes": [
                        "kensho:app:kfinance",
                        "offline_access"
                    ],
                    "redirectMode": "Global",
                    "redirectUrl": "https://global.consent.azure-apim.net/redirect",
                    "properties": {
                        "IsFirstParty": "False",
                        "IsOnbehalfofLoginSupported": false
                    },
                    "customParameters": {
                        "authorizationUrl": {
                            "value": "https://kfinance.kensho.com/integrations/authorize"
                        },
                        "tokenUrl": {
                            "value": "https://kfinance.kensho.com/integrations/token"
                        },
                        "refreshUrl": {
                            "value": "https://kfinance.kensho.com/integrations/token"
                        }
                    }
                }
            }
        },
        "iconBrandColor": "#1A1A2E",
        "scriptOperations": [
            "InvokeMCP"
        ],
        "capabilities": [
            "actions"
        ],
        "publisher": "Troy Taylor"
    }
}
