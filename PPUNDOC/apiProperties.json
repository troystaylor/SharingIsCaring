{
  "properties": {
    "connectionParameters": {
      "dataverseUrl": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Dataverse URL",
          "description": "Your Dataverse environment URL.",
          "tooltip": "Enter just the hostname, e.g., org123.crm.dynamics.com. Do not include https://.",
          "constraints": {
            "tabIndex": 1,
            "required": "true"
          }
        }
      },
      "tenantId": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Tenant ID (Power Platform format)",
          "description": "Your tenant ID in Power Platform format for tenant-scoped APIs.",
          "tooltip": "Format: Default-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (with hyphens removed in the GUID after Default-). Find this in the network tab of PPAC.",
          "constraints": {
            "tabIndex": 2,
            "required": "true"
          }
        }
      },
      "environmentId": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Environment ID",
          "description": "Your Power Platform environment ID.",
          "tooltip": "Find this in the URL of your environment in PPAC.",
          "constraints": {
            "tabIndex": 3,
            "required": "true"
          }
        }
      },
      "environmentId2": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Environment ID (PP API format)",
          "description": "Environment ID in Power Platform API format.",
          "tooltip": "Format: Defaultxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xx (no hyphens, with a period before last 2 chars). Find in network tab.",
          "constraints": {
            "tabIndex": 4,
            "required": "true"
          }
        }
      },
      "api-key": {
        "type": "securestring",
        "uiDefinition": {
          "displayName": "Bearer Token",
          "description": "A bearer token obtained from browser developer tools or OAuth flow.",
          "tooltip": "Open PPAC or make.powerapps.com, press F12, go to Network tab, copy the Authorization header value (without 'Bearer ' prefix).",
          "constraints": {
            "tabIndex": 5,
            "clearText": false,
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#da3b01",
    "capabilities": [],
    "publisher": "Troy Taylor",
    "stackOwner": "Troy Taylor",
