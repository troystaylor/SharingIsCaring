                "type": "securestring",
                "uiDefinition": {
                    "displayName": "Client Secret",
                    "description": "OAuth 2.0 Client Secret paired with the Client ID. Used by the connector to exchange for a Bearer token via POST https://api.smartrecruiters.com/identity/oauth/token.",
