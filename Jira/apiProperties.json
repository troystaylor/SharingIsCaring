{
  "properties": {
    "connectionParameters": {
      "token": {
        "type": "oauthSetting",
        "oAuthSettings": {
          "identityProvider": "oauth2",
          "clientId": "[[REPLACE_WITH_JIRA_CLIENT_ID]]",
          "scopes": [
            "read:jira-work write:jira-work read:jira-user"
          ],
          "redirectMode": "GlobalPerConnector",
          "customParameters": {
            "AuthorizationUrl": {
              "value": "https://auth.atlassian.com/authorize"
            },
            "TokenUrl": {
              "value": "https://auth.atlassian.com/oauth/token"
            },
            "RefreshUrl": {
              "value": "https://auth.atlassian.com/oauth/token"
            }
          }
        }
      },
      "token:clientId": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Client ID",
          "schema": {
            "type": "string",
            "description": "Client ID from your Atlassian OAuth 2.0 (3LO) app"
          },
          "tooltip": "Found in your Atlassian developer console",
          "constraints": {
            "required": "true"
          }
        }
      },
      "token:clientSecret": {
        "type": "securestring",
        "uiDefinition": {
          "displayName": "Client Secret",
          "schema": {
            "type": "securestring",
            "description": "Client secret from your Atlassian OAuth 2.0 (3LO) app"
          },
          "tooltip": "Found in your Atlassian developer console",
          "constraints": {
            "required": "true"
          }
        }
      },
      "siteUrl": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Jira site URL",
          "description": "Base URL for your Jira site, for example https://your-domain.atlassian.net",
          "tooltip": "Used to route REST API calls",
          "constraints": {
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#0052CC",
    "capabilities": [
      "actions"
    ],
    "publisher": "Troy Taylor",
    "stackOwner": "Atlassian",
    "scriptOperations": [
      "InvokeMCP",
      "ListProjects",
      "SearchIssues",
      "GetIssue",
      "CreateIssue",
      "UpdateIssue",
      "ListIssueTypes",
      "GetProjectRoles",
      "GetProjectStatuses",
      "ListComments",
      "AddComment",
      "GetTransitions",
      "TransitionIssue",
      "ListFields",
      "GetUser",
      "SearchUsers"
    ]
  }
}
