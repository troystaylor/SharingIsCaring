{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "version": "1.0.0",
  "id": "{{GUID}}",
  "packageName": "com.troytaylor.netsuite-cowork-plugin",
  "developer": {
    "name": "Troy Taylor",
    "websiteUrl": "https://troystaylor.com",
    "privacyUrl": "https://troystaylor.com/privacy",
    "termsOfUseUrl": "https://troystaylor.com/terms"
  },
  "name": {
    "short": "NetSuite Cowork Plugin",
    "full": "NetSuite Cowork Plugin"
  },
  "description": {
    "short": "Query, brief, and CRUD NetSuite records in Cowork.",
    "full": "Brings Oracle NetSuite into Copilot Cowork via an in-tenant MCP server. Supports SuiteQL queries, full record CRUD, sublist line management, record metadata discovery, and scenario skills for customer briefings, open sales orders, AR aging, vendor lookup, and recent transactions."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#1A1A1A",
  "agentSkills": [
    { "folder": "./skills/customer-briefing" },
    { "folder": "./skills/open-sales-orders-review" },
    { "folder": "./skills/ar-aging-snapshot" },
    { "folder": "./skills/vendor-lookup" },
    { "folder": "./skills/recent-transactions" },
    { "folder": "./skills/run-suiteql-query" },
    { "folder": "./skills/list-records" },
    { "folder": "./skills/get-record-details" },
    { "folder": "./skills/create-record" },
    { "folder": "./skills/update-record" },
    { "folder": "./skills/delete-record" },
    { "folder": "./skills/get-record-metadata" },
    { "folder": "./skills/manage-sublist-lines" }
  ],
  "agentConnectors": [
    {
      "id": "netsuite-cowork-plugin-mcp",
      "displayName": "NetSuite Cowork Plugin",
      "description": "Query, brief, and CRUD Oracle NetSuite records via an in-tenant MCP server.",
      "toolSource": {
        "remoteMcpServer": {
          "mcpServerUrl": "https://<YOUR-CONTAINER-APP-FQDN>/mcp/full",
          "authorization": {
            "type": "OAuthPluginVault",
            "referenceId": "{{OAUTH_REFERENCE_ID}}"
          }
        }
      }
    }
  ]
}
