{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "version": "1.0.0",
  "id": "{{GUID}}",
  "packageName": "com.troytaylor.salesforce-cowork-plugin",
  "developer": {
    "name": "Troy Taylor",
    "websiteUrl": "https://troystaylor.com",
    "privacyUrl": "https://troystaylor.com/privacy",
    "termsOfUseUrl": "https://troystaylor.com/terms"
  },
  "name": {
    "short": "Salesforce Cowork Plugin",
    "full": "Salesforce Cowork Plugin"
  },
  "description": {
    "short": "CRUD Salesforce accounts, opportunities, contacts, and tasks in Cowork.",
    "full": "Provides full CRUD workflows over Salesforce accounts, opportunities, contacts, and tasks in Copilot Cowork. Supports account and opportunity briefings, health summaries, risk detection, next-best-action guidance, contact discovery, task review, and controlled write actions for create and update on accounts, opportunities, contacts, and tasks through an in-tenant MCP server."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0176D3",
  "agentSkills": [
    { "folder": "./skills/account-briefing" },
    { "folder": "./skills/opportunity-health-summary" },
    { "folder": "./skills/next-best-action" },
    { "folder": "./skills/update-opportunity" },
    { "folder": "./skills/log-call-notes" },
    { "folder": "./skills/open-risks-and-blockers" },
    { "folder": "./skills/create-opportunity" },
    { "folder": "./skills/find-contacts" },
    { "folder": "./skills/add-contact" },
    { "folder": "./skills/update-account" },
    { "folder": "./skills/create-account" },
    { "folder": "./skills/update-contact" },
    { "folder": "./skills/review-tasks" }
  ],
  "agentConnectors": [
    {
      "id": "salesforce-cowork-plugin-mcp",
      "displayName": "Salesforce Cowork Plugin",
      "description": "Read, create, and update Salesforce accounts, opportunities, contacts, and tasks via an in-tenant MCP server.",
      "toolSource": {
        "remoteMcpServer": {
          "mcpServerUrl": "https://<YOUR-CONTAINER-APP-FQDN>/mcp/full",
          "authorization": {
            "type": "OAuthPluginVault",
            "referenceId": "{{OAUTH_REFERENCE_ID}}"
          }
        }
      }
    }
  ]
}
