    "/contentsafety/text:shieldPrompt": {
      "post": {
        "operationId": "ShieldPrompt",
        "summary": "Shield Prompt",
        "description": "Detect prompt injection attacks in user prompts and documents. Identifies both direct jailbreak attempts and indirect attacks embedded in documents. Use before passing user input to an LLM.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "userPrompt": {
                  "type": "string",
                  "description": "The user prompt to check for direct injection attacks.",
                  "x-ms-summary": "User Prompt"
                },
                "documents": {
                  "type": "array",
                  "description": "Documents to check for indirect injection attacks (e.g., email content, retrieved documents).",
                  "x-ms-summary": "Documents",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Prompt shield analysis complete.",
            "schema": {
              "type": "object",
              "properties": {
                "userPromptAnalysis": {
                  "type": "object",
                  "description": "Analysis of the user prompt.",
                  "x-ms-summary": "User Prompt Analysis",
                  "properties": {
                    "attackDetected": {
                      "type": "boolean",
                      "description": "Whether a prompt injection attack was detected.",
                      "x-ms-summary": "Attack Detected"
                    }
                  }
                },
                "documentsAnalysis": {
                  "type": "array",
                  "description": "Analysis of each document.",
                  "x-ms-summary": "Documents Analysis",
                  "items": {
                    "type": "object",
                    "properties": {
                      "attackDetected": {
                        "type": "boolean",
                        "description": "Whether an injection attack was detected in this document.",
                        "x-ms-summary": "Attack Detected"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." }
        }
      }
    },
    "/contentsafety/text:detectProtectedMaterial": {
      "post": {
        "operationId": "DetectProtectedMaterial",
        "summary": "Detect Protected Material (Text)",
        "description": "Check if LLM-generated text contains known protected material such as song lyrics, articles, recipes, or web content. Use on AI outputs before returning to users to avoid copyright issues.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["text"],
              "properties": {
                "text": {
                  "type": "string",
                  "description": "The AI-generated text to check (min 110 characters, max 10,000).",
