                      },
                      "text": {
                        "type": "string",
                        "description": "The text pattern to block (max 128 characters).",
                        "x-ms-summary": "Text",
                        "maxLength": 128
                      }
                    },
                    "required": [
                      "text"
                    ]
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Items added.",
            "schema": {
              "type": "object",
              "properties": {
                "blocklistItems": {
                  "type": "array",
                  "description": "Added items with assigned IDs.",
                  "x-ms-summary": "Items",
                  "items": {
                    "type": "object",
                    "properties": {
                      "blocklistItemId": { "type": "string", "x-ms-summary": "Item ID" },
                      "text": { "type": "string", "x-ms-summary": "Text" },
                      "description": { "type": "string", "x-ms-summary": "Description" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
