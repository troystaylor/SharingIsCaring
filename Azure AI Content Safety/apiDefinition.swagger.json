        "parameters": [
          {
            "name": "blocklistName",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The blocklist name (alphanumeric, dashes, underscores).",
            "x-ms-summary": "Blocklist Name",
            "x-ms-url-encoding": "single"
          },
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version"
          },
          {
            "name": "Content-Type",
            "in": "header",
            "required": true,
            "type": "string",
            "default": "application/merge-patch+json",
            "x-ms-visibility": "internal"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "description": {
                  "type": "string",
                  "description": "Description of the blocklist.",
                  "x-ms-summary": "Description"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blocklist created or updated.",
            "schema": {
              "type": "object",
              "properties": {
                "blocklistName": { "type": "string", "x-ms-summary": "Name" },
                "description": { "type": "string", "x-ms-summary": "Description" }
              }
            }
          },
          "201": { "description": "Blocklist created." }
        }
      }
    },
    "/contentsafety/text/blocklists/{blocklistName}:addOrUpdateBlocklistItems": {
      "post": {
        "operationId": "AddBlocklistItems",
        "summary": "Add Blocklist Items",
        "description": "Add or update items in a text blocklist.",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "blocklistName",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The blocklist name.",
            "x-ms-summary": "Blocklist Name",
            "x-ms-url-encoding": "single"
          },
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
