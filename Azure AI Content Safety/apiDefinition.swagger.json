    "/contentsafety/text:detectGroundedness": {
      "post": {
        "operationId": "DetectGroundedness",
        "summary": "Detect Groundedness",
        "description": "Check if an LLM response is grounded (factually consistent) with the provided source materials. Detects hallucinations and fabricated information. Preview feature.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-15-preview",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["domain", "task", "text", "groundingSources"],
              "properties": {
                "domain": {
                  "type": "string",
                  "description": "The domain of the content.",
                  "x-ms-summary": "Domain",
                  "default": "Generic",
                  "enum": ["Generic", "Medical"],
                  "x-ms-visibility": "advanced"
                },
                "task": {
                  "type": "string",
                  "description": "The task type.",
                  "x-ms-summary": "Task",
                  "default": "QnA",
                  "enum": ["QnA", "Summarization"],
                  "x-ms-visibility": "advanced"
                },
                "text": {
                  "type": "string",
                  "description": "The LLM-generated text to check for groundedness (max 7,500 characters).",
                  "x-ms-summary": "Text"
                },
                "groundingSources": {
                  "type": "array",
                  "description": "The source documents the text should be grounded in (max 55,000 chars total).",
                  "x-ms-summary": "Grounding Sources",
                  "items": {
                    "type": "string"
                  }
                },
                "qna": {
                  "type": "object",
                  "description": "Query information for QnA task type.",
                  "x-ms-summary": "QnA Query",
                  "x-ms-visibility": "advanced",
                  "properties": {
                    "query": {
                      "type": "string",
                      "description": "The user's question.",
                      "x-ms-summary": "Query"
                    }
                  }
                },
                "reasoning": {
                  "type": "boolean",
                  "description": "Enable reasoning for detailed ungroundedness explanations. Requires Azure OpenAI resource.",
                  "x-ms-summary": "Enable Reasoning",
                  "x-ms-visibility": "advanced",
                  "default": false
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Groundedness detection complete.",
            "schema": {
              "type": "object",
              "properties": {
                "ungroundedDetected": {
                  "type": "boolean",
                  "description": "Whether ungrounded content was detected.",
                  "x-ms-summary": "Ungrounded Detected"
                },
                "ungroundedPercentage": {
                  "type": "number",
                  "description": "Percentage of text that is ungrounded.",
                  "x-ms-summary": "Ungrounded Percentage"
                },
                "ungroundedDetails": {
                  "type": "array",
                  "description": "Details of ungrounded segments.",
                  "x-ms-summary": "Ungrounded Details",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": { "type": "string", "x-ms-summary": "Ungrounded Text" },
                      "reason": { "type": "string", "x-ms-summary": "Reason" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." }
        }
      }
    },
