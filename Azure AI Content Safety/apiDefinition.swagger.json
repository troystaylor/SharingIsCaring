{
  "swagger": "2.0",
  "info": {
    "title": "Azure AI Content Safety",
    "description": "Analyze text and images for harmful content using Azure AI Content Safety. Detects Hate, SelfHarm, Sexual, and Violence with severity scoring. Detect prompt injection attacks, protected material in LLM output, and ungrounded responses. Manage custom blocklists. Includes MCP protocol support for Copilot Studio.",
    "version": "1.0.0",
    "contact": {
      "name": "Troy Taylor",
      "email": "troy@troystaylor.com"
    }
  },
  "host": "placeholder.cognitiveservices.azure.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/contentsafety/text:analyze": {
      "post": {
        "operationId": "AnalyzeText",
        "summary": "Analyze Text",
        "description": "Analyze text for harmful content. Returns severity scores (0-6) for Hate, SelfHarm, Sexual, and Violence categories, plus any blocklist matches.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version",
            "description": "The API version."
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "text"
              ],
              "properties": {
                "text": {
                  "type": "string",
                  "description": "The text to analyze (max 10,000 characters).",
                  "x-ms-summary": "Text",
                  "maxLength": 10000
                },
                "categories": {
                  "type": "array",
                  "description": "Categories to analyze. If omitted, all four are analyzed.",
                  "x-ms-summary": "Categories",
                  "x-ms-visibility": "advanced",
                  "items": {
                    "type": "string",
                    "enum": [
                      "Hate",
                      "SelfHarm",
                      "Sexual",
                      "Violence"
                    ]
                  }
                },
                "blocklistNames": {
                  "type": "array",
                  "description": "Names of custom blocklists to check against.",
                  "x-ms-summary": "Blocklist Names",
                  "x-ms-visibility": "advanced",
                  "items": {
                    "type": "string"
                  }
                },
                "haltOnBlocklistHit": {
                  "type": "boolean",
                  "description": "If true, skip harm analysis when a blocklist match is found.",
                  "x-ms-summary": "Halt on Blocklist Hit",
                  "x-ms-visibility": "advanced"
                },
                "outputType": {
                  "type": "string",
                  "description": "Severity level granularity.",
                  "x-ms-summary": "Output Type",
                  "x-ms-visibility": "advanced",
                  "default": "FourSeverityLevels",
                  "enum": [
                    "FourSeverityLevels",
                    "EightSeverityLevels"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Text analyzed.",
            "schema": {
              "type": "object",
              "properties": {
                "categoriesAnalysis": {
                  "type": "array",
                  "description": "Severity scores per harm category.",
                  "x-ms-summary": "Categories Analysis",
                  "items": {
                    "type": "object",
                    "properties": {
                      "category": {
                        "type": "string",
                        "description": "Harm category.",
                        "x-ms-summary": "Category"
                      },
                      "severity": {
                        "type": "integer",
                        "description": "Severity level (0=safe, higher=more severe).",
                        "x-ms-summary": "Severity"
                      }
                    }
                  }
                },
                "blocklistsMatch": {
                  "type": "array",
                  "description": "Matched blocklist items.",
                  "x-ms-summary": "Blocklist Matches",
                  "items": {
                    "type": "object",
                    "properties": {
                      "blocklistName": {
                        "type": "string",
                        "x-ms-summary": "Blocklist Name"
                      },
                      "blocklistItemId": {
                        "type": "string",
                        "x-ms-summary": "Item ID"
                      },
                      "blocklistItemText": {
                        "type": "string",
                        "x-ms-summary": "Matched Text"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/contentsafety/image:analyze": {
      "post": {
        "operationId": "AnalyzeImage",
        "summary": "Analyze Image",
        "description": "Analyze an image for harmful content. Returns severity scores (0-6) for Hate, SelfHarm, Sexual, and Violence categories. Accepts base64-encoded image or blob URL.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "2024-09-01",
            "x-ms-visibility": "internal",
            "x-ms-summary": "API Version",
            "description": "The API version."
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "image"
              ],
              "properties": {
                "image": {
                  "type": "object",
                  "description": "The image to analyze.",
                  "x-ms-summary": "Image",
                  "properties": {
                    "content": {
                      "type": "string",
                      "description": "Base64-encoded image content.",
                      "x-ms-summary": "Content (Base64)"
                    },
                    "blobUrl": {
                      "type": "string",
                      "description": "URL to the image in Azure Blob Storage.",
                      "x-ms-summary": "Blob URL"
                    }
                  }
                },
                "categories": {
                  "type": "array",
                  "description": "Categories to analyze. If omitted, all four are analyzed.",
                  "x-ms-summary": "Categories",
                  "x-ms-visibility": "advanced",
                  "items": {
                    "type": "string",
                    "enum": [
                      "Hate",
                      "SelfHarm",
                      "Sexual",
                      "Violence"
                    ]
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image analyzed.",
            "schema": {
              "type": "object",
              "properties": {
                "categoriesAnalysis": {
                  "type": "array",
                  "description": "Severity scores per harm category.",
                  "x-ms-summary": "Categories Analysis",
                  "items": {
                    "type": "object",
                    "properties": {
                      "category": {
                        "type": "string",
                        "x-ms-summary": "Category"
                      },
                      "severity": {
                        "type": "integer",
                        "x-ms-summary": "Severity"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/contentsafety/check/text": {
      "post": {
        "operationId": "CheckTextSafety",
        "summary": "Check Text Safety",
        "description": "Simplified safety check — returns a clear safe/unsafe result with the highest-severity category. Set a threshold to control sensitivity. No API call overhead beyond AnalyzeText — this operation calls the same endpoint and simplifies the response.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "text"
              ],
              "properties": {
                "text": {
                  "type": "string",
                  "description": "The text to check.",
                  "x-ms-summary": "Text",
                  "maxLength": 10000
                },
                "threshold": {
                  "type": "integer",
                  "format": "int32",
                  "description": "Maximum allowed severity (0-6). Content at or above this level is flagged as unsafe. Default: 2.",
                  "x-ms-summary": "Threshold",
                  "default": 2,
                  "minimum": 0,
                  "maximum": 6
                },
                "blocklistNames": {
                  "type": "array",
                  "description": "Optional blocklists to check.",
                  "x-ms-summary": "Blocklist Names",
                  "x-ms-visibility": "advanced",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Safety check result.",
            "schema": {
              "type": "object",
              "properties": {
                "is_safe": {
                  "type": "boolean",
                  "description": "True if no category exceeds the threshold and no blocklist matches.",
                  "x-ms-summary": "Is Safe"
                },
                "highest_category": {
                  "type": "string",
                  "description": "The category with the highest severity.",
                  "x-ms-summary": "Highest Category"
                },
                "highest_severity": {
                  "type": "integer",
                  "description": "The highest severity score found.",
                  "x-ms-summary": "Highest Severity"
                },
                "threshold": {
                  "type": "integer",
                  "description": "The threshold used.",
                  "x-ms-summary": "Threshold"
                },
                "blocklist_hit": {
                  "type": "boolean",
                  "description": "True if any blocklist items matched.",
                  "x-ms-summary": "Blocklist Hit"
                },
                "categories": {
                  "type": "object",
                  "description": "All category severity scores.",
                  "x-ms-summary": "Categories",
                  "properties": {
                    "Hate": { "type": "integer", "x-ms-summary": "Hate" },
                    "SelfHarm": { "type": "integer", "x-ms-summary": "Self Harm" },
                    "Sexual": { "type": "integer", "x-ms-summary": "Sexual" },
                    "Violence": { "type": "integer", "x-ms-summary": "Violence" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/contentsafety/check/image": {
      "post": {
        "operationId": "CheckImageSafety",
        "summary": "Check Image Safety",
        "description": "Simplified image safety check — returns a clear safe/unsafe result with the highest-severity category.",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "image_content": {
                  "type": "string",
                  "description": "Base64-encoded image content.",
                  "x-ms-summary": "Image Content (Base64)"
                },
                "image_url": {
                  "type": "string",
                  "description": "URL to the image in Azure Blob Storage.",
                  "x-ms-summary": "Image URL"
                },
                "threshold": {
                  "type": "integer",
                  "format": "int32",
                  "description": "Maximum allowed severity (0-6). Default: 2.",
                  "x-ms-summary": "Threshold",
                  "default": 2,
                  "minimum": 0,
                  "maximum": 6
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Safety check result.",
            "schema": {
              "type": "object",
              "properties": {
                "is_safe": { "type": "boolean", "x-ms-summary": "Is Safe" },
                "highest_category": { "type": "string", "x-ms-summary": "Highest Category" },
                "highest_severity": { "type": "integer", "x-ms-summary": "Highest Severity" },
                "threshold": { "type": "integer", "x-ms-summary": "Threshold" },
                "categories": {
                  "type": "object",
                  "x-ms-summary": "Categories",
                  "properties": {
                    "Hate": { "type": "integer", "x-ms-summary": "Hate" },
                    "SelfHarm": { "type": "integer", "x-ms-summary": "Self Harm" },
                    "Sexual": { "type": "integer", "x-ms-summary": "Sexual" },
                    "Violence": { "type": "integer", "x-ms-summary": "Violence" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request." },
          "401": { "description": "Unauthorized." },
          "429": { "description": "Too many requests." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/contentsafety/text/blocklists": {
      "get": {
        "operationId": "ListBlocklists",
        "summary": "List Blocklists",
        "description": "List all custom text blocklists.",
