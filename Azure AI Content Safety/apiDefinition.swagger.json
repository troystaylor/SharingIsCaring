            "x-ms-summary": "API Version"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "blocklistItems"
              ],
              "properties": {
                "blocklistItems": {
                  "type": "array",
                  "description": "Items to add to the blocklist.",
                  "x-ms-summary": "Items",
                  "items": {
                    "type": "object",
                    "properties": {
                      "description": {
                        "type": "string",
                        "description": "Description of why this term is blocked.",
