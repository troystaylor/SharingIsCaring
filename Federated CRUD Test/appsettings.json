{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "organizations",
    "ClientId": "<SERVER_CLIENT_ID>",
    "Audiences": [
      "<SERVER_CLIENT_ID>"
    ]
  },
  "Mcp": {
    "ServerUrl": "<CONTAINER_APP_URL>",
    "Scope": "api://<SERVER_CLIENT_ID>/access_as_user"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
