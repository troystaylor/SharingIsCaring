{
    "swagger": "2.0",
    "info": {
        "title": "Service Principal API Connector",
        "description": "Template for authenticating any API using Azure AD service principal (client credentials flow). Replace placeholders with your API details.",
        "version": "1.0.0",
        "contact": {
            "name": "Troy Taylor",
            "email": "troy@troystaylor.com",
            "url": "https://github.com/troystaylor"
        }
    },
    "host": "your-api-host.example.com",
    "basePath": "/",
    "schemes": [
        "https"
    ],
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "paths": {},
    "securityDefinitions": {
        "oauth2": {
            "type": "oauth2",
            "flow": "application",
            "authorizationUrl": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/authorize",
            "tokenUrl": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token",
            "scopes": {
                "https://your-api-app-id-uri/.default": "Your API Scope Description"
            }
        }
    },
    "security": [
        {
            "oauth2": []
        }
    ],
    "x-ms-connector-metadata": [
        {
            "propertyName": "Website",
            "propertyValue": "https://your-api-website.example.com"
        },
        {
            "propertyName": "Privacy policy",
            "propertyValue": "https://your-api-website.example.com/privacy"
        },
        {
            "propertyName": "Categories",
            "propertyValue": "Custom;API"
        }
    ]
}