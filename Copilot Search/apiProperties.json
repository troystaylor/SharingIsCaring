          "identityProvider": "aad",
          "clientId": "[INSERT_YOUR_APP_REGISTRATION_CLIENT_ID]",
          "scopes": [
            "Mail.Read",
            "Calendars.Read",
            "Chat.Read",
            "ChannelMessage.Read.All",
            "Files.Read.All",
            "Sites.Read.All",
            "ExternalItem.Read.All",
            "People.Read"
          ],
          "redirectMode": "Global",
          "redirectUrl": "https://global.consent.azure-apim.net/redirect",
          "properties": {
