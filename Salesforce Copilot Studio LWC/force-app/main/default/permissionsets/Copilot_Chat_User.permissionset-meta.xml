<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/09/metadata">
    <description>Grants access to the Copilot Chat Lightning Web Component and its Apex controller. Assign to users who need the Copilot Studio chat widget.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Copilot Chat User</label>
    <classAccesses>
        <apexClass>CopilotStudioController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Copilot_Interaction__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Severity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Channel__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Case__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Topic__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.KB_Articles_Shown__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Summary__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.Conversation_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Copilot_Interaction__c.User_Email__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
