{
  "name": "pw-workspaces-broker",
  "version": "1.0.0",
  "description": "Playwright Workspaces broker — full browser automation on Azure remote Chromium browsers via CDP, exposed as REST APIs for Power Platform connectors",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "Troy Taylor",
  "repository": {
    "type": "git",
    "url": "https://github.com/troystaylor/sharingiscaring.git",
    "directory": "Playwright Workspaces/broker-service"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "playwright",
    "playwright-workspaces",
    "browser-automation",
    "cdp",
    "mcp",
    "power-platform",
    "copilot-studio",
    "custom-connector"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright-core": "1.52.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2",
    "vitest": "^3.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  }
}
